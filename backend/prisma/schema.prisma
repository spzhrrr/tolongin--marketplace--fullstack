datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================
// ENUM
// ============================================================

enum WorkSubmissionStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
  DISPUTED
}

enum ReviewType {
  BUYER_TO_SELLER
  SELLER_TO_BUYER
}

enum BadgeType {
  TOP_RATED
  FAST_DELIVERY
  VERIFIED_PRO
  RISING_TALENT
  TRUSTED_BUYER
  TOP_SELLER
}

// ============================================================
// BANK ACCOUNT
// ============================================================
model BankAccount {
  id            String   @id @default(cuid())
  userId        String
  bankName      String
  accountNumber String
  accountName   String
  bankProof     String?
  isDefault     Boolean  @default(false)
  isVerified    Boolean  @default(false)
  createdAt     DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("bank_accounts")
}

// ============================================================
// CATEGORY
// ============================================================
model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  icon      String?
  createdAt DateTime  @default(now())

  services  Service[]
  jobs      Job[]

  @@map("categories")
}

// ============================================================
// USER
// ============================================================
model User {
  id              String    @id @default(cuid())
  email           String    @unique
  password        String
  name            String
  phone           String?
  avatar          String?

  role            String    @default("USER")

  emailVerified     Boolean   @default(false)
  emailVerifiedAt   DateTime?
  phoneVerified     Boolean   @default(false)
  phoneVerifiedAt   DateTime?
  emailOtpHash      String?
  emailOtpExpiresAt DateTime?
  phoneOtpHash      String?
  phoneOtpExpiresAt DateTime?

  ktpNumber         String?
  ktpPhoto          String?
  ktpSelfie         String?
  ktpVerified       Boolean   @default(false)
  ktpVerifiedAt     DateTime?
  ktpRejectedReason String?  @db.Text
  ktpSubmittedAt    DateTime?

  bio              String?  @db.Text
  city             String?
  skills           String   @default("[]")  @db.Text
  rating           Float    @default(0)
  reviewCount      Int      @default(0)
  totalOrders      Int      @default(0)
  completedOrders  Int      @default(0)
  balance          Float    @default(0)
  verified         Boolean  @default(false)

  isActive         Boolean  @default(true)
  isBanned         Boolean  @default(false)
  bannedReason     String?  @db.Text
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  // Relasi
  services        Service[]
  jobs            Job[]
  reviewsGiven    Review[]      @relation("ReviewsGiven")
  reviewsReceived Review[]      @relation("ReviewsReceived")
  payments        Payment[]
  withdrawals     Withdrawal[]
  bankAccounts    BankAccount[]
  notifications   Notification[]
  messages        Message[]
  disputesRaised  Dispute[]     @relation("DisputeRaiser")
  passwordResets  PasswordReset[]
  favorites       Favorite[]
  buyerOrders     Order[]       @relation("BuyerOrders")
  sellerOrders    Order[]       @relation("SellerOrders")
  applications    Application[]
  portfolio       Portfolio[]
  badges          UserBadge[]

  @@map("users")
}

// ============================================================
// SERVICE
// ============================================================
model Service {
  id            String    @id @default(cuid())
  sellerId      String
  categoryId    String
  title         String
  description   String  @db.Text
  price         Float
  priceType     String    @default("FIXED")
  deliveryTime  Int
  revisionCount Int       @default(1)
  images        String    @default("[]")  @db.Text
  isActive      Boolean   @default(true)
  isFeatured    Boolean   @default(false)
  viewCount     Int       @default(0)
  orderCount    Int       @default(0)
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  simulationOrderCreatedAt DateTime?

  seller        User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  category      Category  @relation(fields: [categoryId], references: [id])
  orders        Order[]
  reviews       Review[]
  favorites     Favorite[]

  @@index([sellerId])
  @@index([categoryId])
  @@map("services")
}

// ============================================================
// JOB
// ============================================================
model Job {
  id                String        @id @default(cuid())
  buyerId           String
  categoryId        String
  title             String
  description       String  @db.Text
  budget            Float
  budgetType        String        @default("FIXED")
  deadline          DateTime?
  location          String?
  isOnline          Boolean       @default(false)
  urgency           String        @default("NORMAL")
  skills            String        @default("[]")  @db.Text
  status            String        @default("OPEN")
  viewCount         Int           @default(0)
  applicationsCount Int           @default(0)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  
  simulationApplicationCreatedAt DateTime?

  buyer             User          @relation(fields: [buyerId], references: [id], onDelete: Cascade)
  category          Category      @relation(fields: [categoryId], references: [id])
  applications      Application[]

  @@index([buyerId])
  @@index([categoryId])
  @@map("jobs")
}

// ============================================================
// APPLICATION
// ============================================================
model Application {
  id               String    @id @default(cuid())
  jobId            String
  sellerId         String
  coverLetter      String  @db.Text
  proposedPrice    Float
  proposedDuration Int
  portfolioIds     String    @default("[]")  @db.Text
  status           String    @default("PENDING")
  rejectionReason  String?
  reviewedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  simulationAcceptedAt   DateTime?
  simulationApplicationCreatedAt DateTime?

  job              Job       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  seller           User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  order            Order?

  @@unique([jobId, sellerId])
  @@map("applications")
}

// ============================================================
// ORDER
// ============================================================
model Order {
  id                  String    @id @default(cuid())
  buyerId             String
  sellerId            String
  serviceId           String?
  jobId               String?   
  applicationId       String?   @unique
  title               String
  amount              Float
  fee                 Float     @default(0)
  totalAmount         Float
  status              String    @default("WAITING_CONFIRMATION")
  escrowStatus        String    @default("UNPAID")
  notes               String?  @db.Text
  deliveryType        String    @default("DIGITAL")
  deliveryAddress     String?  @db.Text
  workProof           String?  @db.Text
  workNote            String?  @db.Text
  workSubmission      String?  @db.Text
  workSubmittedAt     DateTime?
  workApprovedAt      DateTime?
  workRejectedAt      DateTime?
  workRejectionReason String?  @db.Text
  workSubmissionNote   String?  @db.Text
  workSubmissionFiles  String                @default("[]")  @db.Text
  workSubmissionDate   DateTime?
  workSubmissionStatus WorkSubmissionStatus?
  
  simulationAcceptedAt   DateTime?
  simulationWorkSubmittedAt DateTime?
  simulationApprovedAt   DateTime?

  autoReleaseAt       DateTime?
  fundsReleasedAt     DateTime?
  deadline            DateTime?
  completedAt         DateTime?
  cancelledAt         DateTime?
  cancellationReason  String?  @db.Text

  timeline            String    @default("[]") @db.Text
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  buyer               User         @relation("BuyerOrders", fields: [buyerId], references: [id])
  seller              User         @relation("SellerOrders", fields: [sellerId], references: [id])
  service             Service?     @relation(fields: [serviceId], references: [id])
  application         Application? @relation(fields: [applicationId], references: [id])
  reviews             Review[]
  payments            Payment[]
  dispute             Dispute?
  conversation        Conversation?

  @@index([buyerId])
  @@index([sellerId])
  @@index([jobId])
  @@map("orders")
}

// ============================================================
// REVIEW
// ============================================================
model Review {
  id           String     @id @default(cuid())
  orderId      String
  reviewerId   String
  revieweeId   String
  serviceId    String?
  rating       Int
  comment      String  @db.Text
  reviewType   ReviewType @default(BUYER_TO_SELLER)
  images       String     @default("[]")  @db.Text
  reply        String?  @db.Text
  replyAt      DateTime?
  isAnonymous  Boolean    @default(false)
  helpfulCount Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  order        Order      @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reviewer     User       @relation("ReviewsGiven", fields: [reviewerId], references: [id])
  reviewee     User       @relation("ReviewsReceived", fields: [revieweeId], references: [id])
  service      Service?   @relation(fields: [serviceId], references: [id])

  @@unique([orderId, reviewerId])
  @@map("reviews")
}

// ============================================================
// PAYMENT
// ============================================================
model Payment {
  id            String    @id @default(cuid())
  orderId       String
  userId        String
  amount        Float
  fee           Float     @default(0)
  totalAmount   Float
  method        String
  status        String    @default("PENDING")
  transactionId String?
  paymentUrl    String?
  paidAt        DateTime?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user          User      @relation(fields: [userId], references: [id])

  @@map("payments")
}

// ============================================================
// WITHDRAWAL
// ============================================================
model Withdrawal {
  id              String    @id @default(cuid())
  sellerId        String
  amount          Float
  bankName        String
  accountNumber   String
  accountName     String
  status          String    @default("PENDING")
  processedAt     DateTime?
  processedBy     String?
  transactionId   String?
  rejectionReason String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  seller          User      @relation(fields: [sellerId], references: [id], onDelete: Cascade)

  @@map("withdrawals")
}

// ============================================================
// NOTIFICATION
// ============================================================
model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String  @db.Text
  data      String?  @db.Text
  actionUrl String?
  isRead    Boolean   @default(false)
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================================
// CONVERSATION
// ============================================================
model Conversation {
  id            String    @id @default(cuid())
  participants  String  @db.Text
  orderId       String?   @unique
  lastMessage   String?  @db.Text
  lastMessageAt DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  order         Order?    @relation(fields: [orderId], references: [id])
  messages      Message[]

  @@map("conversations")
}

// ============================================================
// MESSAGE
// ============================================================
model Message {
  id             String    @id @default(cuid())
  conversationId String
  senderId       String
  content        String  @db.Text
  attachment     String?  @db.Text
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id])

  @@index([conversationId])
  @@map("messages")
}

// ============================================================
// DISPUTE
// ============================================================
model Dispute {
  id            String    @id @default(cuid())
  orderId       String    @unique
  raisedBy      String
  reason        String  @db.Text
  description   String  @db.Text
  evidence      String?  @db.Text
  status        String    @default("PENDING")
  resolution    String?  @db.Text
  resolvedBy    String?
  resolvedAt    DateTime?
  autoResolveAt DateTime?
  messages      String?  @db.Text
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  order         Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  raiser        User      @relation("DisputeRaiser", fields: [raisedBy], references: [id])

  @@map("disputes")
}

// ============================================================
// PASSWORD RESET
// ============================================================
model PasswordReset {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_resets")
}

// ============================================================
// PLATFORM SETTING
// ============================================================
model PlatformSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String  @db.Text
  updatedAt DateTime @updatedAt

  @@map("platform_settings")
}

// ============================================================
// ACTIVITY LOG
// ============================================================
model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  String?  @db.Text
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("activity_logs")
}

// ============================================================
// FAVORITE
// ============================================================
model Favorite {
  id        String   @id @default(cuid())
  userId    String
  serviceId String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  service   Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([userId, serviceId])
  @@map("favorites")
}

// ============================================================
// PORTFOLIO
// ============================================================
model Portfolio {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?  @db.Text
  imageUrl    String?  @db.Text
  projectUrl  String?  @db.Text
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("portfolios")
}

// ============================================================
// USER BADGE
// ============================================================
model UserBadge {
  id        String    @id @default(cuid())
  userId    String
  badgeType BadgeType
  earnedAt  DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeType])
  @@index([userId])
  @@map("user_badges")
}